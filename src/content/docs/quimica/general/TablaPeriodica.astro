// ⚡ categoría
function categoria(n){
  if([1,6,7,8,15,16].includes(n)) return "no-metal";
  if([9,17,35,53,85,117].includes(n)) return "halogeno";
  if([2,10,18,36,54,86,118].includes(n)) return "gas";
  if(n>=57 && n<=71) return "lant";
  if(n>=89 && n<=103) return "act";
  if([3,11,19,37,55,87].includes(n)) return "alcalino";
  if([4,12,20,38,56,88].includes(n)) return "alcalinoterreo";
  return "transicion";
}for(let i=0;i<118;i++){
  const n=i+1;
  const [g,p] = posiciones[n];

  const el={
    n,
    s:simbolos[i],
    nom:nombres[i],
    en:electroneg[i] || "-",
    dens:densidad[i] || "-",
    masa:masa[i] || "-"
  };

  const d=document.createElement("div");
  d.className="elemento";
  d.classList.add(categoria(n));

  d.style.gridColumn=g;
  d.style.gridRow=p;

  d.innerHTML=`
    <div class="numero">${n}</div>
    <div class="simbolo">${el.s}</div>
    <div class="nombre">${el.nom}</div>
    <div class="extra">${el.masa}</div>
