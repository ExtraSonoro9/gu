<style is:global>
:root[data-theme="dark"] .elemento{
  color:#000; /* texto negro SIEMPRE */
}
#tabla-wrapper{
  overflow-x:auto;
  width:100%;
  padding:10px;
}

#tabla{
  display:grid;
  grid-template-columns:repeat(18,75px);
  grid-auto-rows:75px;
  gap:4px;
  justify-content:start;
}

.elemento{
  border:1px solid #000;
  padding:3px;
  border-radius:4px;

  display:flex;
  flex-direction:column;

  align-items:center;

  height:100%;
  overflow:hidden;
  position:relative;
}
.numero{
  position:absolute;
  top:2px;
  left:4px;
  font-size:8px;
}
.simbolo{
  font-size:18px;
  font-weight:bold;
  margin-top:10px;
}
.nombre{
  font-size:8px;
  text-align:center;
  margin-top:-2px;
  line-height:1;
}
.extra{
  font-size:7px;
  line-height:1;
  margin-top:auto;
  margin-top:-0.2px;
}
/* colores */
.alcalino{background:#ff6666;}
.alcalinoterreo{background:#ffdead;}
.transicion{background:#ffc0c0;}
.no-metal{background:#a0ffa0;}
.gas{background:#a0e0ff;}
.halogeno{background:#ffff99;}
.lant{background:#ffbfff;}
.act{background:#ff99cc;}

#info{
  margin-top:20px;
  padding:10px;
  border:2px solid black;
}
.elemento:hover{
  transform:scale(1.1);
  z-index:10;
  box-shadow:2px 2px 6px rgba(0,0,0,0.5);
}
#tabla{
  margin-bottom:25px;
}
</style>

<div id="tabla-wrapper">
  <div id="tabla"></div>
</div>

<div id="info">Click en un elemento</div>
